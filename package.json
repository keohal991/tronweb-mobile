        "test": "jest --verbose",
        "postinstall": "./patch.sh"
    },
    "dependencies": {
        "@babel/runtime": "7.26.10",
        "axios": "1.13.5",
        "buffer": "6.0.3",
        "crypto-browserify": "3.12.0",
